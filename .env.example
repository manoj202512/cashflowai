# ============================================================
# CashFlowAI Environment Variables
# ============================================================

# --- App ---
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-change-in-production
APP_BASE_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Next.js Frontend ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-key

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_STARTER_PRICE_ID=price_starter
STRIPE_GROWTH_PRICE_ID=price_growth
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise

# --- QuickBooks ---
QUICKBOOKS_CLIENT_ID=your-qb-client-id
QUICKBOOKS_CLIENT_SECRET=your-qb-client-secret
QUICKBOOKS_REDIRECT_URI=http://localhost:8000/api/v1/integrations/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=sandbox

# --- Xero ---
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
XERO_REDIRECT_URI=http://localhost:8000/api/v1/integrations/xero/callback

# --- OpenAI (LangChain) ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4-turbo-preview

# --- ElevenLabs Voice ---
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id

# --- Resend Email ---
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=collections@yourdomain.com
RESEND_FROM_NAME=CashFlowAI Collections

# --- Twilio SMS ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# --- Redis (Rate Limiting & Cache) ---
REDIS_URL=redis://localhost:6379

# --- n8n ---
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# --- Monitoring ---
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
LOGFIRE_TOKEN=your-logfire-token

# --- Rate Limits (per tenant per month) ---
DEFAULT_AI_CALLS_LIMIT=1000
DEFAULT_VOICE_CALLS_LIMIT=100
DEFAULT_EMAIL_LIMIT=5000
DEFAULT_SMS_LIMIT=1000
DEFAULT_API_REQUESTS_LIMIT=50000
